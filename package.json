{
   "name": "@silvermine/eslint-config",
   "version": "3.2.1",
   "description": "JS Code Standards for all SilverMine projects - ESLint enforcement",
   "type": "module",
   "scripts": {
      "build": "tsc -p tsconfig.build.json",
      "prepare": "npm run build",
      "check-node-version": "check-node-version --npm 11.6.1",
      "test": "vitest run --coverage",
      "test:watch": "vitest",
      "commitlint": "commitlint --from 3d0c92c",
      "eslint": "eslint .",
      "markdownlint": "markdownlint-cli2",
      "standards": "npm run commitlint && npm run markdownlint && npm run eslint",
      "release:preview": "node ./node_modules/@silvermine/standardization/scripts/release.js preview",
      "release:prep-changelog": "node ./node_modules/@silvermine/standardization/scripts/release.js prep-changelog",
      "release:finalize": "node ./node_modules/@silvermine/standardization/scripts/release.js finalize"
   },
   "main": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "types": "./dist/index.d.ts",
         "default": "./dist/index.js"
      },
      "./node-tests": {
         "types": "./dist/node-tests.d.ts",
         "default": "./dist/node-tests.js"
      },
      "./partials/*": {
         "types": "./dist/partials/*.d.ts",
         "default": "./dist/partials/*.js"
      },
      "./partials/vue/*": {
         "types": "./dist/partials/vue/*.d.ts",
         "default": "./dist/partials/vue/*.js"
      },
      "./plugin": {
         "types": "./dist/plugin/index.d.ts",
         "default": "./dist/plugin/index.js"
      },
      "./plugin/types": {
         "types": "./dist/plugin/types.d.ts",
         "default": "./dist/plugin/types.js"
      }
   },
   "files": [
      "dist",
      "README.md",
      "LICENSE",
      "CHANGELOG.md"
   ],
   "repository": {
      "type": "git",
      "url": "git+https://github.com/silvermine/eslint-config-silvermine.git"
   },
   "keywords": [
      "eslint",
      "eslintconfig"
   ],
   "author": "Jeremy Thomerson",
   "license": "MIT",
   "bugs": {
      "url": "https://github.com/silvermine/eslint-config-silvermine/issues"
   },
   "homepage": "https://github.com/silvermine/eslint-config-silvermine#readme",
   "dependencies": {
      "@eslint/js": "9.39.2",
      "@stylistic/eslint-plugin": "5.6.1",
      "@typescript-eslint/parser": "8.49.0",
      "eslint-plugin-vue": "10.6.2",
      "globals": "16.5.0",
      "typescript-eslint": "8.49.0",
      "vue-eslint-parser": "10.2.0"
   },
   "devDependencies": {
      "@silvermine/standardization": "2.2.3",
      "@silvermine/typescript-config": "github:silvermine/typescript-config#ea8b79237aee970a15ab85beedf8e524478ef671",
      "@types/eslint": "9.6.1",
      "@types/node": "25.0.1",
      "@vitest/coverage-v8": "3.1.4",
      "@vue/tsconfig": "0.7.0",
      "cz-conventional-changelog": "3.3.0",
      "eslint": "9.39.1",
      "typescript": "5.9.3",
      "vitest": "3.1.4",
      "vue": "3.5.25"
   },
   "peerDependencies": {
      "eslint": ">= 9"
   },
   "config": {
      "commitizen": {
         "path": "./node_modules/cz-conventional-changelog"
      }
   }
}
