{
   "extends": "@silvermine/typescript-config/tsconfig.esm.json",
   "include": [
      "test-cases/vue/**/*.vue",
      "test-cases/vue/**/*.ts",
   ],
   "compilerOptions": {
      "rootDir": "./",
      "composite": true,
      "noEmit": true,
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "skipLibCheck": true,
      "esModuleInterop": true,
      "strict": true,
      "lib": ["ES2022", "DOM"],
      "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.web.tsbuildinfo",
      "types": ["node"]
   }
}
